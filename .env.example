# ────────────────────────────────────────────────────
# Web3Hub monorepo — copy to .env and fill values
# ────────────────────────────────────────────────────

# ── Database (Node API / Express) ───────────────────
# PostgreSQL connection string（api-server 必需）
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Node API (artifacts/api-server) ─────────────────
PORT=8080

# ── Python FastAPI (backend/) — Web3 结构化提取 ───────
# DeepSeek（OpenAI 兼容）: https://api.deepseek.com
DEEPSEEK_API_KEY=
# 可选覆盖（一般无需修改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# 或其它 OpenAI 兼容服务：
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Python API 端口（pnpm dev / Docker）
BACKEND_PORT=8000
PYTHON_API_PORT=8000

# FastAPI CORS（逗号分隔多个来源）
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000

# ── DeepSeek / OpenRouter（Node RSS auto-scraper 等）──
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── OpenAI（Node 手动 ai-extractor）──────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Scraper / admin（Node）───────────────────────────
SCRAPE_INTERNAL_KEY=your-secret-key-here
# SCRAPE_CRON_SCHEDULE=0 */2 * * *
ADMIN_TOKEN_SECRET=your-random-32-char-secret-here

# ── Frontend（Vite 本地开发）──────────────────────────
# PORT=5173
# BASE_PATH=/
# Express 代理（默认 http://127.0.0.1:8080）
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
# Docker dev 下由 compose 注入 backend-dev；本机可写：
# VITE_EXTRACT_PROXY_TARGET=http://127.0.0.1:8000

# ── Docker Compose ────────────────────────────────────
# FRONTEND_PORT=80
# FRONTEND_DEV_PORT=5173
