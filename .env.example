# ────────────────────────────────────────────────────
# Web3Hub — Environment Variables Reference
# Copy this file to .env and fill in the values.
# ────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── API Server ───────────────────────────────────────
# Port for the Express backend (default: 3000)
PORT=8080

# ── DeepSeek / OpenRouter (RSS auto-scraper) ─────────
# Used by auto-scraper.ts to call DeepSeek-V3 via OpenRouter
# Sign up at https://openrouter.ai and create an API key
OPENROUTER_API_KEY=sk-or-...
# Optional: override the base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── OpenAI (manual AI extractor) ─────────────────────
# Used by ai-extractor.ts for on-demand page extraction
# Can also point to any OpenAI-compatible endpoint (e.g. DeepSeek directly)
OPENAI_API_KEY=sk-...
# Optional: override base URL for a compatible provider
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Scraper Settings ──────────────────────────────────
# Internal API key to protect the manual scrape trigger endpoint
SCRAPE_INTERNAL_KEY=your-secret-key-here
# Cron schedule for automatic scraping (default: every 2 hours)
# SCRAPE_CRON_SCHEDULE=0 */2 * * *

# ── Admin Auth ────────────────────────────────────────
# Secret used to sign admin JWT tokens.
# Without this, tokens are invalidated on every server restart.
ADMIN_TOKEN_SECRET=your-random-32-char-secret-here

# ── Frontend (Vite dev server only) ──────────────────
# These are only needed for local development; not required in production.
# PORT=3000
# BASE_PATH=/
