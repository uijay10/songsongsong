# ────────────────────────────────────────────────────
# Web3Hub — Environment Variables Reference
# Copy this file to .env and fill in the values.
# ────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────
# PostgreSQL connection string (required for api-server)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Server Port ───────────────────────────────────────
# Backend listening port (default: 3000)
PORT=3000

# ── DeepSeek API (主要使用的AI) ───────────────────────
# 用于 auto-scraper.ts 和 ai-extractor.ts
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# 可选：直接指定 DeepSeek 的地址（通常不需要改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── OpenRouter (备用，如果你要通过 OpenRouter 调用 DeepSeek) ─
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── OpenAI 兼容接口 (备用) ───────────────────────────
# 如果你有其他 OpenAI 兼容服务，可以在这里配置
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Scraper Settings ──────────────────────────────────
# 内部接口保护密钥（防止别人随意触发抓取）
SCRAPE_INTERNAL_KEY=your-secret-key-here

# 自动抓取定时任务（默认每2小时一次）
# SCRAPE_CRON_SCHEDULE=0 */2 * * *

# ── Admin Authentication ─────────────────────────────
# 管理员 JWT 签名密钥（建议使用随机32位以上字符串）
ADMIN_TOKEN_SECRET=your-random-32-char-secret-here

# ── Frontend Settings (仅本地开发需要) ───────────────
# BASE_PATH=/
